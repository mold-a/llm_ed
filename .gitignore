# ============================================================
# СЕКРЕТНЫЕ КЛЮЧИ — самое важное, никогда не должно уйти в git
# ============================================================
.env
.env.local
.env.production

# ============================================================
# ВИРТУАЛЬНОЕ ОКРУЖЕНИЕ PYTHON
# ============================================================
venv/
.venv/
env/

# ============================================================
